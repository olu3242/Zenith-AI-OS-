# ============================================================
# ZENITH AI OS — Environment Variables
# ============================================================

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Zenith AI OS"
ZENITH_AIOS_VERSION=1.0.0

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
DATABASE_URL=postgresql://postgres:password@localhost:5432/zenith_aios

# AI Providers (Provider Abstraction Layer)
AI_PROVIDER=anthropic                      # anthropic | openai | local | azure
ANTHROPIC_API_KEY=sk-ant-your-key
OPENAI_API_KEY=sk-your-key
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
LOCAL_MODEL_ENDPOINT=http://localhost:11434

# Default Models
AI_ORCHESTRATOR_MODEL=claude-opus-4-5
AI_WORKER_MODEL=claude-sonnet-4-5
AI_FAST_MODEL=claude-haiku-3-5
AI_EMBEDDING_MODEL=text-embedding-3-small

# Vector Search
VECTOR_DIMENSIONS=1536
VECTOR_SIMILARITY_THRESHOLD=0.7
VECTOR_MAX_RESULTS=10

# Security
ENCRYPTION_KEY=your-32-char-encryption-key
JWT_SECRET=your-jwt-secret
COOKIE_SECRET=your-cookie-secret
SESSION_DURATION_HOURS=24
AUDIT_LOG_RETENTION_DAYS=365

# Email
EMAIL_PROVIDER=resend                     # resend | sendgrid | ses
RESEND_API_KEY=re_your-key
EMAIL_FROM=noreply@zenith-aios.com

# Queue / Events
QUEUE_PROVIDER=postgres                   # postgres | redis | bull
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_DELAY_MS=5000
DEAD_LETTER_RETENTION_DAYS=30

# Observability
TELEMETRY_ENABLED=true
TRACE_SAMPLE_RATE=0.1
METRICS_ENABLED=true
ALERTS_WEBHOOK_URL=

# Billing (Stripe-ready, can stub)
BILLING_ENABLED=false
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-secret

# Plugin System
PLUGIN_REGISTRY_URL=https://plugins.zenith-aios.com
MAX_INSTALLED_PLUGINS=10

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_TOKENS_PER_DAY=500000

# Feature Flags
FEATURE_AUDIT_ENGINE=true
FEATURE_PLUGIN_MARKETPLACE=true
FEATURE_HUMAN_OVERSIGHT=true
FEATURE_CANARY_MODE=false
FEATURE_SHADOW_MODE=false

# Deployment
DEPLOYMENT_TARGET=vercel                  # vercel | docker | self-host
DEPLOYMENT_REGION=us-east-1
# ── LLM Providers ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Supabase / Postgres ─────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgresql://postgres:password@localhost:5432/zenith_aios

# ── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── n8n ─────────────────────────────────────────────────────────
N8N_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key

# ── App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Audit ───────────────────────────────────────────────────────
AUDIT_OUTPUT_DIR=./docs/audit
